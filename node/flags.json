{
  "flags": {
    "greetings": {
      "state": "ENABLED",
      "variants": {
        "noder": "Hi noder",
        "hallo": "Hallo Welt!",
        "hello": "Hello World!",
        "goodbye": "Goodbye World!"
      },
      "defaultVariant": "hello",
      "targeting": {
        "if": [
          { "sem_ver": [ { "var": "nodeVersion" }, ">=", "20.0.0" ] },
          "noder",
          { "===": [ { "var": "language" }, "de" ] },
          "hallo"
        ]
      }
    }
  }
}
