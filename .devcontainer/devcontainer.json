// Dev container for the Fun With Flags polyglot OpenFeature demo.
// One container, five languages — so the talk doesn't stall on a toolchain install.
{
  "name": "Fun With Flags",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21"
    }
  },
  "forwardPorts": [8080, 8013, 8014, 8015, 8016, 3000, 4317, 4318],
  "portsAttributes": {
    "8080": {
      "label": "App"
    },
    "8013": {
      "label": "flagd gRPC"
    },
    "8014": {
      "label": "flagd HTTP"
    },
    "8015": {
      "label": "flagd sync"
    },
    "8016": {
      "label": "flagd sync"
    },
    "3000": {
      "label": "Grafana"
    },
    "4317": {
      "label": "OTLP gRPC"
    },
    "4318": {
      "label": "OTLP HTTP"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.java",
        "golang.go",
        "ms-python.python",
        "dbaeumer.vscode-eslint",
        "humao.rest-client"
      ]
    }
  },
  "postCreateCommand": "bash -lc 'cd java-spring && ./mvnw -q dependency:resolve || true; cd ../java-quarkus && ./mvnw -q dependency:resolve || true; cd ../go-chi && go mod download || true; cd ../python-fastapi && pip install -e . || true; cd ../node-express && npm ci || true'"
}
