// Intermediate phase — steps 2.1 through 5.2.
// flagd, targeting, hooks, remote flagd, Testcontainers. Docker-in-Docker
// is enabled so `docker compose up` works inside the Codespace; the LGTM
// observability and k6 loadgen ports are not forwarded — those belong to
// the Expert phase.
{
  "name": "Fun With Flags · Intermediate",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21"
    }
  },
  "forwardPorts": [8080, 8013, 8014, 8015, 8016],
  "portsAttributes": {
    "8080": {
      "label": "App"
    },
    "8013": {
      "label": "flagd gRPC eval"
    },
    "8014": {
      "label": "flagd management/metrics"
    },
    "8015": {
      "label": "flagd sync (IN_PROCESS)"
    },
    "8016": {
      "label": "flagd OFREP"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.java",
        "golang.go",
        "ms-python.python",
        "dbaeumer.vscode-eslint",
        "humao.rest-client"
      ]
    }
  },
  "postCreateCommand": "bash -lc 'cd java-spring && ./mvnw -q dependency:resolve || true; cd ../java-quarkus && ./mvnw -q dependency:resolve || true; cd ../go-chi && go mod download || true; cd ../python-fastapi && pip install -e . || true; cd ../node-express && npm ci || true'"
}
