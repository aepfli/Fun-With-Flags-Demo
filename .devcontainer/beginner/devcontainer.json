// Beginner phase — steps 1.1 and 1.2 only.
// SDK basics + InMemoryProvider; no flagd, no Docker, no observability.
// Boots fast because Docker-in-Docker is intentionally absent — there is
// nothing in this phase that needs a container.
{
  "name": "Fun With Flags · Beginner",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21"
    }
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "App"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.java",
        "golang.go",
        "ms-python.python",
        "dbaeumer.vscode-eslint",
        "humao.rest-client"
      ]
    }
  },
  "postCreateCommand": "bash -lc 'cd java-spring && ./mvnw -q dependency:resolve || true; cd ../java-quarkus && ./mvnw -q dependency:resolve || true; cd ../go-chi && go mod download || true; cd ../python-fastapi && pip install -e . || true; cd ../node-express && npm ci || true'"
}
