{
  "flags": {
    "greetings": {
      "state": "ENABLED",
      "variants": {
        "pythonista": "Hi pythonista",
        "hallo": "Hallo Welt!",
        "hello": "Hello World!",
        "goodbye": "Goodbye World!"
      },
      "defaultVariant": "hello",
      "targeting": {
        "if": [
          { "sem_ver": [ { "var": "pythonVersion" }, ">=", "3.10.0" ] },
          "pythonista",
          { "===": [ { "var": "language" }, "de" ] },
          "hallo"
        ]
      }
    },
    "new_greeting_algo": {
      "state": "ENABLED",
      "variants": {
        "off": false,
        "on": true
      },
      "defaultVariant": "off",
      "targeting": {
        "fractional": [
          ["off", 100],
          ["on", 0]
        ]
      }
    }
  }
}
